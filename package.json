{
  "name": "form-builder",
  "version": "1.0.0",
  "main": "./dist/form-builder.umd.js",
  "module": "./dist/form-builder.mjs",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/form-builder.mjs",
      "require": "./dist/form-builder.umd.js",
      "types": "./dist/types/index.d.ts"
    },
    "./style.css": "./dist/form-builder.css"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && npm run build:types",
    "build:types": "vue-tsc -p tsconfig.build.json --declaration --emitDeclarationOnly --outDir dist/types",
    "preview": "vite preview"
  },
  "files": [
    "dist",
    "src"
  ],
  "dependencies": {
    "csv-parser": "^3.2.0",
    "lucide-vue-next": "^1.0.0",
    "survey-core": "^2.5.18",
    "survey-creator-core": "^2.5.18",
    "survey-creator-vue": "^2.5.18",
    "survey-vue3-ui": "^2.5.18",
    "vue": "^3.5.30",
    "vue-i18n": "^11.3.0"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.0",
    "typescript": "~5.9.3",
    "vite": "^8.0.1",
    "vite-plugin-compression": "^0.5.1",
    "vue-tsc": "^3.2.5"
  }
}
